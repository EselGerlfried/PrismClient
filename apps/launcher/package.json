{
  "name": "@prism/launcher",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite-electron",
    "build": "tsc -p tsconfig.main.json && vite build",
    "dist": "pnpm build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.main.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@prism/api-types": "workspace:*",
    "@prism/design-system": "workspace:*",
    "electron-updater": "^6.3.9",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.0",
    "electron": "^32.2.5",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.0",
    "typescript": "^5.5.3",
    "vite": "^5.4.10",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.1.1"
  },
  "build": {
    "appId": "app.prismclient",
    "productName": "PrismClient",
    "directories": { "output": "release" },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "EselGerlfried",
      "repo": "PrismClient"
    }
  }
}
